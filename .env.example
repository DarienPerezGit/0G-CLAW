# =============================================================================
# 0G-Claw — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# 0G Storage
# Docs: https://docs.0g.ai/build-with-0g/storage-sdk
# -----------------------------------------------------------------------------

# EVM-compatible RPC for the 0G chain (testnet or mainnet)
OG_STORAGE_RPC=https://evmrpc-testnet.0g.ai

# Storage indexer endpoint — used to locate where files are stored
OG_STORAGE_INDEXER=https://indexer-storage-testnet-standard.0g.ai

# Private key of the wallet that signs storage transactions
# Get testnet tokens at: https://build.0g.ai
OG_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# 0G Compute
# Docs: https://docs.0g.ai/build-with-0g/compute-network
# -----------------------------------------------------------------------------

# Proxy API endpoint for 0G Compute inference
OG_COMPUTE_ENDPOINT=https://api.0g.ai/v1

# Model to use for inference
# Options: qwen3.6-plus | GLM-5-FP8 | qwen3-VL
OG_COMPUTE_MODEL=qwen3.6-plus

# -----------------------------------------------------------------------------
# ENS (optional — required for ENS identity track)
# -----------------------------------------------------------------------------

# ENS label for the agent identity (without .eth suffix)
# Example: my-agent → resolves to my-agent.0gclaw.eth
# ENS_AGENT_LABEL=my-agent

# -----------------------------------------------------------------------------
# Fallback — used when 0G services are unavailable
# -----------------------------------------------------------------------------

# OpenAI API key (fallback compute only)
# OPENAI_API_KEY=

# Local storage path (fallback memory only)
# LOCAL_STORAGE_PATH=~/.openclaw
