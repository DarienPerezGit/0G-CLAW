# =============================================================================
# 0G-Claw — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# 0G Storage
# Docs: https://docs.0g.ai/build-with-0g/storage-sdk
# -----------------------------------------------------------------------------

# EVM-compatible RPC for the 0G chain (testnet or mainnet)
OG_STORAGE_RPC=https://evmrpc-testnet.0g.ai

# Storage indexer endpoint — use the turbo endpoint (standard is under maintenance)
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# Private key of the wallet that signs storage transactions
# Get testnet tokens at: https://faucet.0g.ai
OG_PRIVATE_KEY=

# Deprecated — no longer required. The adapter uses indexer upload/download.
# OG_KV_RPC=
# OG_FLOW_CONTRACT=
# OG_KV_STREAM_ID=

# -----------------------------------------------------------------------------
# 0G Compute
# Docs: https://docs.0g.ai/build-with-0g/compute-network
# -----------------------------------------------------------------------------

# Proxy API endpoint for 0G Compute inference (legacy direct-proxy approach)
# OG_COMPUTE_ENDPOINT=https://api.0g.ai/v1

# Model to use for inference (resolved automatically from provider metadata)
# OG_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct

# Provider address on the 0G Compute Network
# Testnet providers (Galileo):
#   0xa48f01287233509FD694a22Bf840225062E67836  — qwen/qwen-2.5-7b-instruct
#   0x8e60d466FD16798Bec4868aa4CE38586D5590049  — openai/gpt-oss-20b
#   0x69Eb5a0BD7d0f4bF39eD5CE9Bd3376c61863aE08  — google/gemma-3-27b-it
# Pre-conditions before live inference works:
#   1. Wallet funded with ≥ 3 OG tokens
#   2. broker.ledger.addLedger(3)
#   3. broker.inference.acknowledgeProviderSigner(OG_COMPUTE_PROVIDER)
#   4. broker.ledger.transferFund(OG_COMPUTE_PROVIDER, "inference", amount)
OG_COMPUTE_PROVIDER=

# Set to "true" to enable live 0G Compute integration tests
# Requires OG_STORAGE_RPC, OG_PRIVATE_KEY, OG_COMPUTE_PROVIDER + funded broker
ENABLE_0G_COMPUTE_TESTS=false

# -----------------------------------------------------------------------------
# ENS (optional — required for ENS identity track)
# -----------------------------------------------------------------------------

# ENS label for the agent identity (without .eth suffix)
# Example: my-agent → resolves to my-agent.0gclaw.eth
# ENS_AGENT_LABEL=my-agent

# -----------------------------------------------------------------------------
# Fallback — used when 0G services are unavailable
# -----------------------------------------------------------------------------

# OpenAI API key (fallback compute only)
# OPENAI_API_KEY=

# Local storage path (fallback memory only)
# LOCAL_STORAGE_PATH=~/.openclaw

# -----------------------------------------------------------------------------
# Examples
# -----------------------------------------------------------------------------

# research-agent — required topic to investigate. The agent ID is derived
# from sha256(topic), so the same topic + same wallet on any machine maps
# to the same memory namespace (shared / replayable research).
# RESEARCH_TOPIC=0G Protocol architecture
