{
  "name": "0g-claw",
  "version": "0.1.0",
  "description": "OpenClaw with decentralized memory and compute via 0G Protocol",
  "type": "module",
  "main": "./dist/adapters/memory/IMemoryAdapter.js",
  "types": "./dist/adapters/memory/IMemoryAdapter.d.ts",
  "exports": {
    ".": {
      "types": "./dist/adapters/memory/IMemoryAdapter.d.ts",
      "import": "./dist/adapters/memory/IMemoryAdapter.js"
    },
    "./adapters/memory/*.js": {
      "types": "./dist/adapters/memory/*.d.ts",
      "import": "./dist/adapters/memory/*.js"
    },
    "./adapters/memory/*": {
      "types": "./dist/adapters/memory/*.d.ts",
      "import": "./dist/adapters/memory/*.js"
    },
    "./adapters/compute/*.js": {
      "types": "./dist/adapters/compute/*.d.ts",
      "import": "./dist/adapters/compute/*.js"
    },
    "./adapters/compute/*": {
      "types": "./dist/adapters/compute/*.d.ts",
      "import": "./dist/adapters/compute/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "pnpm build",
    "dev": "tsx watch",
    "example:basic": "tsx examples/basic-agent/agent.ts",
    "example:basic:prod": "node dist/examples/basic-agent/agent.js",
    "example:research": "tsx examples/research-agent/agent.ts",
    "example:research:prod": "node dist/examples/research-agent/agent.js",
    "example:research:inspect": "tsx examples/research-agent/inspect.ts",
    "example:research:inspect:prod": "node dist/examples/research-agent/inspect.js",
    "check:testnet": "tsx scripts/check-testnet.ts",
    "setup:broker": "tsx scripts/setup-compute-broker.ts",
    "conversation": "tsx scripts/conversation.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "^1.2.6",
    "@0glabs/0g-serving-broker": "^0.7.5",
    "@0glabs/0g-ts-sdk": "^0.3.3",
    "@ensdomains/ensjs": "^4.0.2",
    "ethers": "^6.13.5",
    "openai": "^4.97.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "dotenv": "^17.4.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.9.0"
}
